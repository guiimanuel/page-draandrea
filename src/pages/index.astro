---
import '../styles/global.css';

const appointmentUrl = 'https://draandreadoria.my.canva.site';
const instagramUrl = 'https://www.instagram.com/andreadoriahepato';
const locations = [
  {
    name: 'Hospital Real Português - Clínica Real Hepato',
    street: 'Av. Gov. Agamenon Magalhães, 4760 - Paissandu',
    city: 'Recife - PE, 52010-902',
    phonenumber:'(81) 98235-0768',
    whatssapp: 'https://api.whatsapp.com/send?phone=5581982350768&text=Clinica%20Real%20Hepato',
    mapEmbedUrl: 'https://www.google.com/maps?q=Hospital+Real+Portugu%C3%AAs+Cl%C3%ADnica+Real+Hepato+Av.+Gov.+Agamenon+Magalh%C3%A3es,+4760,+Recife,+PE&output=embed'
  },
  {
    name: 'Shopping Recife - Medical Center',
    street: 'R. Padre Carapuceiro, 777 - Boa Viagem',
    city: 'Recife - PE, 51020-900',
    phonenumber:'(81) 99258-5492',
    whatssapp: 'https://api.whatsapp.com/send/?phone=558192585492&text&type=phone_number&app_absent=0',
    mapEmbedUrl: 'https://www.google.com/maps?q=Medical+Center+Shopping+Recife+R.+Padre+Carapuceiro,+777,+Boa+Viagem,+Recife,+PE,+51020-900&output=embed'
  }
];

const credentials = [
  ['CRM/PE', '10930'],
  ['RQE', '693'],
  ['Especialidade', 'Hepatologia'],
  ['Atendimento', 'Recife, PE']
];

const heroTitles = [
  'Título de Especialista em Hepatologia pela Sociedade Brasileira de Hepatologia (SBH) e Associação Médica Brasileira (AMB)',
  'Doutora pela Universidade Federal de Pernambuco',
  'Professora Adjunta da Universidade Federal de Pernambuco',
  'Atuação clínica integrada à realização da elastografia hepática.'
];

const conditions = [
  {
    title: 'Exames alterados',
    text: 'Investigação, diagnóstico e acompanhamento das alterações dos exames do fígado, incluindo as enzimas TGO, TGP, GGT e fosfatase alcalina (FA), bilirrubinas, albumina, ferritina, INR e alterações identificadas no ultrassom hepático.'
  },
  {
    title: 'Gordura no fígado',
    text: 'Investigação, tratamento e acompanhamento da esteatose hepática, com abordagem dos fatores metabólicos relacionados e estratificação do risco de progressão.'
  },
  {
    title: 'Hepatites',
    text: 'Diagnóstico, tratamento e acompanhamento das hepatites virais, autoimune e induzida por medicamentos'
  },
  {
    title: 'Cirrose',
    text: 'Acompanhamento especializado das doenças hepáticas crônicas, com foco na prevenção de complicações e na preservação da função do fígado.'
  }
];

const journeySteps = [
  {
    title: 'Escuta e avaliação clínica',
    text: 'A consulta começa com uma compreensão detalhada dos sintomas, histórico médico, hábitos de vida, medicações em uso e fatores de risco.'
  },
  {
    title: 'Análise integrada dos exames',
    text: 'Exames laboratoriais e de imagem são interpretados em conjunto com a avaliação clínica, permitindo um diagnóstico mais preciso e uma tomada de decisão segura.'
  },
  {
    title: 'Plano de cuidado individualizado',
    text: 'O tratamento é definido de forma personalizada, combinando prevenção de complicações e orientações práticas que possam ser incorporadas à sua rotina.'
  }
];

const instagramPosts = [
  {
    title: 'Post educativo no Instagram',
    url: 'https://www.instagram.com/reel/DaQB9GERiVC/'
  },
  {
    title: 'Post educativo no Instagram',
    url: 'https://www.instagram.com/p/DZqFnOdEVas/'
  },
  {
    title: 'Post educativo no Instagram',
    url: 'https://www.instagram.com/reel/DZDQXJFh0yA/'
  },
  {
    title: 'Post educativo no Instagram',
    url: 'https://www.instagram.com/reel/DY2mGSWh5QI/'
  }
];

const schema = {
  '@context': 'https://schema.org',
  '@type': 'Physician',
  name: 'Dra. Andrea Dória',
  medicalSpecialty: 'Hepatology',
  address: locations.map((location) => ({
    '@type': 'PostalAddress',
    streetAddress: location.street,
    addressLocality: 'Recife',
    addressRegion: 'PE',
    postalCode: location.city.replace('Recife - PE, ', ''),
    addressCountry: 'BR'
  })),
  url: appointmentUrl,
  sameAs: [instagramUrl]
};
---

<!doctype html>
<html lang="pt-BR">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta
      name="description"
      content="Dra. Andrea Dória, médica hepatologista em Recife. Atendimento especializado para saúde do fígado, vias biliares e prevenção de doenças hepáticas."
    />
    <title>Dra. Andrea Dória | Hepatologista em Recife</title>
    <link rel="icon" type="image/png" href="/assets/images/brand/simbolo-verde.png" />
    <script type="application/ld+json" set:html={JSON.stringify(schema)} />
  </head>
  <body>
    <header class="site-header">
      <div class="container site-header__inner">
        <a class="brand" href="#inicio" aria-label="Dra. Andrea Dória Hepatologista">
          <span class="brand__mark" aria-hidden="true">
            <img src="/assets/images/brand/simbolo-verde.png" alt="" />
          </span>
          <span class="brand__copy">
            <span class="brand__name">Dra. Andrea Dória</span>
            <span class="brand__specialty">Hepatologista</span>
            <span class="brand__credential">CRM/PE 10930 · RQE 693</span>
          </span>
        </a>
        <nav class="site-nav" aria-label="Links principais">
          <a href="#atuacao">Atuação</a>
          <a href="#quandoprocurar">Quando Procurar</a>
          <a href="#conteudoeducacional">Conteúdo Educacional</a>
          <a href="#consultorios">Consultórios</a>
          <a class="nav-button" href={appointmentUrl} target="_blank" rel="noopener">Agende</a>
        </nav>
      </div>
    </header>

    <main>
      <section class="hero" id="inicio" aria-label="Dra. Andrea Dória">
        <div class="container hero__content">
          <p class="eyebrow">Hepatologia em Recife</p>
          <h1>Dra. Andrea Dória</h1>
          <p class="hero__credentials">CRM/PE 10930 · RQE 693</p>
          <ul class="hero__titles" aria-label="Titulações e atuação">
            {heroTitles.map((title) => (
              <li>{title}</li>
            ))}
          </ul>
          <p class="hero__text">
            Médica dedicada ao diagnóstico, tratamento e acompanhamento das doenças hepáticas, com atuação baseada em evidências científicas e cuidado individualizado. Realiza avaliação clínica e elastografia hepática, integrando experiência, tecnologia e atenção às necessidades de cada paciente.
          </p>
          <div class="hero__actions">
            <a class="button button--light" href={appointmentUrl} target="_blank" rel="noopener">
              Agende uma consulta
            </a>
            <a class="button button--ghost" href={instagramUrl} target="_blank" rel="noopener">
              Ver Instagram
            </a>
          </div>
        </div>
      </section>

      <section class="credential-strip" aria-label="Credenciais">
        <div class="container credential-strip__grid">
          {credentials.map(([label, value]) => (
            <div class="credential-strip__item">
              <strong>{value}</strong>
              <span>{label}</span>
            </div>
          ))}
        </div>
      </section>

      <section class="section section--white about" id="atuacao">
        <div class="container about__grid">
          <div class="about__media">
            <img
              src="/assets/images/landing/liver-illustration.webp"
              alt="Desenho anatômico de um fígado humano"
              loading="lazy"
            />
          </div>
          <div class="about__copy">
            <p class="eyebrow">Atendimento especializado</p>
            <h2>Hepatologia com precisão clínica e cuidado individualizado</h2>
            <p>
              A hepatologia é a especialidade médica dedicada à prevenção, ao diagnóstico, ao tratamento e ao acompanhamento das doenças do fígado, da vesícula biliar e das vias biliares.
            </p>
            <p>
              A avaliação especializada permite investigar alterações muitas vezes silenciosas, interpretar exames com precisão e definir a conduta mais adequada para cada paciente.
            </p>
          </div>
        </div>
      </section>

      <section class="section section--soft" id="quandoprocurar">
        <div class="container">
          <div class="section__header">
            <p class="eyebrow">Quando procurar</p>
            <h2>Situações que merecem avaliação especializada</h2>
            <p>
              Muitas doenças hepáticas evoluem de forma silenciosa nas fases iniciais. A avaliação especializada permite o diagnóstico precoce, favorece a prevenção da progressão da doença e orienta a conduta mais adequada para cada caso.
            </p>
          </div>
          <div class="condition-grid">
            {conditions.map((condition, index) => (
              <article class="condition__item">
                <span class="condition__number">{String(index + 1).padStart(2, '0')}</span>
                <h3>{condition.title}</h3>
                <p>{condition.text}</p>
              </article>
            ))}
          </div>
        </div>
      </section>

      <section class="section journey">
        <div class="container journey__grid">
          <div class="journey__copy">
            <p class="eyebrow">Como funciona o cuidado</p>
            <h2>Um plano de cuidado individualizado para preservar a saúde do fígado e promover qualidade de vida.</h2>
            <p>
              Cada paciente tem uma história única. Por isso, a consulta integra informações clínicas, exames e estilo de vida para construir um plano de cuidado individualizado, baseado em evidências e adequado à sua realidade.
            </p>
            <div class="journey__steps">
              {journeySteps.map((step, index) => (
                <div class="journey__step">
                  <span>{index + 1}</span>
                  <div>
                    <strong>{step.title}</strong>
                    <p>{step.text}</p>
                  </div>
                </div>
              ))}
            </div>
            <a class="text-link" href={appointmentUrl} target="_blank" rel="noopener">
              Agendar consulta
            </a>
          </div>
          <div class="journey__media">
            <img
              src="/assets/images/landing/andrea-care.jpg"
              alt="Dra. Andrea Dória em retrato profissional"
              loading="lazy"
            />
          </div>
        </div>
      </section>

      <section class="section section--white instagram-section" id="conteudoeducacional">
        <div class="container">
          <div class="section__header section__header--center instagram-section__header">
            <p class="eyebrow">Conteúdo educativo</p>
            <h2>Aprenda mais sobre a saúde do seu fígado</h2>
            <p>
              Conteúdos educativos para esclarecer dúvidas sobre exames, prevenção, diagnóstico e os principais temas da hepatologia.
            </p>
            <a class="text-link instagram-section__link" href={instagramUrl} target="_blank" rel="noopener">
              Abrir perfil no Instagram
            </a>
          </div>
          <div class="instagram-grid">
            {instagramPosts.map((post, index) => (
              <article class="instagram-card" aria-label={post.title}>
                <div class="instagram-card__top">
                  <span>{String(index + 1).padStart(2, '0')}</span>
                  <strong>{post.title}</strong>
                </div>
                <div class="instagram-card__embed">
                  <blockquote
                    class="instagram-media"
                    data-instgrm-permalink={post.url}
                    data-instgrm-version="14"
                  >
                    <a href={post.url} target="_blank" rel="noopener">{post.title}</a>
                  </blockquote>
                </div>
              </article>
            ))}
          </div>
        </div>
      </section>

      <section class="section section--soft location" id="consultorios">
        <div class="container location__grid">
          <div class="location__copy">
            <p class="eyebrow">Consultórios</p>
            <h2>Atendimento em locais de fácil acesso</h2>
            <p>
              Consultas em Recife, em ambientes preparados para oferecer conforto, segurança e cuidado individualizado em hepatologia.
            </p>
          </div>
          <div class="location__places">
            {locations.map((location) => (
              <article class="location__place">
                <div class="location__place-copy">
                  <h3 class="location__clinic">{location.name}</h3>
                  <p class="location__address">
                    {location.street}<br />
                    {location.city}<br/>
                    {location.phonenumber}
                  </p>
                  <a class="button" href={location.whatssapp} target="_blank" rel="noopener">Agendar consulta</a>
                </div>
                <iframe
                  class="location__map"
                  src={location.mapEmbedUrl}
                  title={`Mapa da localização: ${location.name}`}
                  loading="lazy"
                  referrerpolicy="no-referrer-when-downgrade"
                />
              </article>
            ))}
          </div>
        </div>
      </section>
    </main>

    <footer class="site-footer">
      <div class="container footer__inner">
        <img src="/assets/images/brand/logo-branca.png" alt="Dra. Andrea Dória Hepatologista" />
        <div class="footer__links">
          <a href={instagramUrl} target="_blank" rel="noopener">Instagram</a>
          <a href={appointmentUrl} target="_blank" rel="noopener">Agendamento</a>
          <a href="#consultorios">Localização</a>
        </div>
      </div>
      <p class="container footer__copy">
        Copyright © 2026, Andrea Dória. Todos os direitos reservados.
      </p>
    </footer>
    <script async src="https://www.instagram.com/embed.js" is:inline></script>
  </body>
</html>
